# Copy to .env and replace the token with a long random value.
CMDCMD_RELAY_TOKEN=replace-with-a-long-random-token

# Keep the relay local by default. Use a trusted private tunnel or VPN for phones.
CMDCMD_HOST=127.0.0.1
CMDCMD_PORT=8787

# Where uploaded screenshots and metadata are stored before Codex Desktop delivery.
CMDCMD_INBOX_DIR=/Users/jk/.cmd-cmd-relay/inbox

# Codex Desktop visible-composer delivery.
CMDCMD_APPSHOT_OPEN_VIEWER=true
CMDCMD_APPSHOT_VIEWER_BUNDLE=com.apple.Preview
CMDCMD_APPSHOT_CLOSE_VIEWER=true
CMDCMD_APPSHOT_CODEX_BUNDLE=com.openai.codex
CMDCMD_APPSHOT_OPEN_DELAY_MS=750

# Optional paste controls.
# CMDCMD_APPSHOT_OPEN_TIMEOUT_MS=5000
# CMDCMD_APPSHOT_PASTE_DELAY_MS=400
# CMDCMD_APPSHOT_PASTE_TIMEOUT_MS=10000
