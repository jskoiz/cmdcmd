# Copy to .env and replace the token with a long random value.
CODEXSHOT_RELAY_TOKEN=replace-with-a-long-random-token

# Keep the relay local by default. Use a trusted private tunnel or VPN for phones.
CODEXSHOT_HOST=127.0.0.1
CODEXSHOT_PORT=8787

# Where uploaded screenshots and metadata are stored before they are sent to Codex.
CODEXSHOT_INBOX_DIR=/Users/jk/.cmd-cmd-relay/inbox

# Delivery mode:
# - app-server: durable background delivery to a Codex thread.
# - desktop-appshot: open the phone screenshot on the Mac and trigger Codex Desktop Appshot.
CODEXSHOT_DELIVERY_MODE=app-server

# Desktop Appshot mode. CODEXSHOT_APPSHOT_HELPER is required when
# CODEXSHOT_DELIVERY_MODE=desktop-appshot.
# CODEXSHOT_APPSHOT_HELPER=/Users/jk/Documents/Codex/2026-06-04/are-you-able-to-inspect-the/outputs/codex-active-appshot
# CODEXSHOT_APPSHOT_HOTKEY=DoubleCommand
# CODEXSHOT_APPSHOT_OPEN_VIEWER=true
# CODEXSHOT_APPSHOT_VIEWER_BUNDLE=com.apple.Preview
# CODEXSHOT_APPSHOT_TARGET_BUNDLE=com.apple.Preview
# CODEXSHOT_APPSHOT_OPEN_DELAY_MS=750

# The project directory Codex should run from when it receives a capture.
CODEXSHOT_CODEX_CWD=.

# Optional default thread. If unset, cmd+cmd can still send a per-capture
# threadHint; if both are empty, the relay starts a new Codex thread.
# CODEXSHOT_CODEX_THREAD_ID=

# Optional Codex execution controls.
# CODEXSHOT_CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex
# CODEXSHOT_CODEX_MODEL=
CODEXSHOT_CODEX_SANDBOX=read-only
CODEXSHOT_CODEX_APPROVAL_POLICY=never
CODEXSHOT_CODEX_WEB_SEARCH_MODE=disabled
# CODEXSHOT_CODEX_REQUEST_TIMEOUT_MS=15000
# CODEXSHOT_CODEX_TURN_TIMEOUT_MS=600000
